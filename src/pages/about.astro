---
import Layout from "../layouts/Layout.astro";
export const prerender = false;
import * as os from "os";

const hostName = os.hostname();
const platform = os.platform();
const arch = os.arch();

function getMemInfo() {
  const total = os.totalmem();
  const free = os.freemem();
  const used = total - free;
  const usage = ((used / total) * 100).toFixed(1);
  const gb = (n: number) => (n / 1024 ** 3).toFixed(2);
  return {
    total: gb(total),
    used: gb(used),
    free: gb(free),
    usage,
  };
}

function getCpuInfo() {
  const cpus = os.cpus();
  const info = cpus.reduce(
    (acc, c) => {
      acc.cpuNum += 1;
      acc.user += c.times.user;
      acc.sys += c.times.sys;
      acc.idle += c.times.idle;
      acc.total += c.times.user + c.times.sys + c.times.idle;
      return acc;
    },
    { user: 0, sys: 0, idle: 0, total: 0, cpuNum: 0 }
  );
  return {
    cpuNum: info.cpuNum,
    model: cpus[0]?.model?.trim() ?? "unknown",
    sys: ((info.sys / info.total) * 100).toFixed(1),
    used: ((info.user / info.total) * 100).toFixed(1),
    free: ((info.idle / info.total) * 100).toFixed(1),
  };
}

const mem = getMemInfo();
const cpu = getCpuInfo();
const uptime = (os.uptime() / 3600).toFixed(1);

function bar(pct: number, width = 24) {
  const filled = Math.round((pct / 100) * width);
  return "█".repeat(filled) + "░".repeat(width - filled);
}
---

<Layout title="">
  <section class="about">
    <!-- whoami -->
    <div class="block">
      <div class="cmd"><span class="prompt">$</span> whoami</div>
      <pre class="out">krismile · programmer
"今日江头两三春，可怜和叶度残春。"

写一些 Web 前端、Astro、TypeScript、设计的笔记。
偶尔记些工程之外的事。
</pre>
    </div>

    <!-- uname -->
    <div class="block">
      <div class="cmd"><span class="prompt">$</span> uname -a</div>
      <pre class="out">{hostName} · {platform} · {arch} · uptime {uptime}h</pre>
    </div>

    <!-- system stats -->
    <div class="block">
      <div class="cmd"><span class="prompt">$</span> system_profiler --short</div>
      <div class="stats">
        <div class="stat">
          <div class="stat-head">
            <span class="key">cpu</span>
            <span class="val muted">{cpu.cpuNum}× · {cpu.model.slice(0, 36)}</span>
          </div>
          <div class="bar" aria-hidden="true"><span>{bar(parseFloat(cpu.used))}</span></div>
          <div class="stat-foot">
            <span>used <span class="num">{cpu.used}%</span></span>
            <span class="sep">·</span>
            <span>sys <span class="num">{cpu.sys}%</span></span>
            <span class="sep">·</span>
            <span>idle <span class="num">{cpu.free}%</span></span>
          </div>
        </div>

        <div class="stat">
          <div class="stat-head">
            <span class="key">mem</span>
            <span class="val muted">{mem.total} GiB total</span>
          </div>
          <div class="bar" aria-hidden="true"><span>{bar(parseFloat(mem.usage))}</span></div>
          <div class="stat-foot">
            <span>used <span class="num">{mem.used} GiB</span></span>
            <span class="sep">·</span>
            <span>free <span class="num">{mem.free} GiB</span></span>
            <span class="sep">·</span>
            <span class="num">{mem.usage}%</span>
          </div>
        </div>
      </div>
    </div>

    <!-- contact -->
    <div class="block">
      <div class="cmd"><span class="prompt">$</span> cat contact.txt</div>
      <pre class="out">github   <a href="https://github.com" class="link">github.com/krismile</a>
rss      <a href="/rss.xml" class="link">/rss.xml</a>
</pre>
    </div>

    <div class="block">
      <div class="cmd">
        <span class="prompt">$</span>
        <span class="term-cursor"></span>
      </div>
    </div>
  </section>
</Layout>

<style>
  .about {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding: 1rem 0;
  }
  .block { display: flex; flex-direction: column; gap: 0.5rem; }
  .cmd { font-size: 1.0625rem; color: var(--text-primary); }
  .prompt { color: var(--accent); margin-right: 0.5rem; }
  .out {
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.75;
    padding-left: 1.25rem;
    margin: 0;
    font-family: inherit;
    white-space: pre-wrap;
    background: transparent;
    border: 0;
  }
  .link {
    color: var(--accent);
    border-bottom: 1px dashed var(--accent-dim);
  }
  .link:hover { border-bottom-style: solid; }

  .stats {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    padding-left: 1.25rem;
  }
  @media (min-width: 768px) {
    .stats { grid-template-columns: 1fr 1fr; }
  }
  .stat {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0.875rem 1.125rem;
    border: 1px solid var(--border-default);
    border-radius: 4px;
    background: var(--surface);
    font-size: 0.875rem;
  }
  .stat-head {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
  }
  .key { color: var(--accent); font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
  .muted { color: var(--text-muted); }
  .val.muted {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .bar {
    color: var(--accent-dim);
    line-height: 1;
    letter-spacing: -0.05em;
    overflow: hidden;
  }
  .bar span { color: var(--accent); }
  .stat-foot {
    display: flex;
    gap: 0.5rem;
    color: var(--text-muted);
    font-size: 0.8125rem;
  }
  .num { color: var(--text-primary); }
  .sep { color: var(--text-faint); }
</style>
