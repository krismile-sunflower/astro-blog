---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const allPosts = await getCollection("posts");
  const uniqueTags = [...new Set(allPosts.map((p) => p.data.tags).flat())];
  return uniqueTags.map((tag) => ({
    params: { tag },
    props: {
      posts: allPosts
        .filter((p) => p.data.tags.includes(tag))
        .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
    },
  }));
}

const { tag } = Astro.params;
const { posts } = Astro.props;

function pad(n: number, w = 2) { return n.toString().padStart(w, "0"); }
function fmtDate(d: Date) {
  return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}`;
}
---

<Layout title="">
  <section class="tag-page">
    <header class="head">
      <div class="cmd">
        <span class="prompt">$</span> grep -l
        <span class="arg">{`"#${tag}"`}</span> posts/*.md
      </div>
      <div class="meta">
        <span>total <span class="num">{posts.length}</span></span>
        <span class="sep">·</span>
        <a class="back" href="/tags">← all tags</a>
      </div>
    </header>

    <ul class="posts">
      {posts.map((post: any) => (
        <li class="post">
          <a href={`/posts/${post.slug}`} class="row" data-astro-prefetch>
            <span class="date">{fmtDate(new Date(post.data.pubDate))}</span>
            <span class="title">
              <span class="chev">›</span>
              {post.data.title}
            </span>
            <p class="desc">{post.data.description}</p>
            <div class="tags">
              {post.data.tags.map((t: string) => (
                <span class={`tag ${t === tag ? "current" : ""}`}>#{t}</span>
              ))}
            </div>
          </a>
        </li>
      ))}
    </ul>
  </section>
</Layout>

<style>
  .tag-page { display: flex; flex-direction: column; gap: 1.5rem; padding: 1rem 0; }
  .head {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding-bottom: 1rem;
    border-bottom: 1px dashed var(--border-default);
  }
  .cmd { font-size: 1.0625rem; color: var(--text-primary); }
  .prompt { color: var(--accent); margin-right: 0.5rem; }
  .arg { color: var(--accent-soft); }
  .meta { padding-left: 1.25rem; font-size: 0.875rem; color: var(--text-muted); display: flex; gap: 0.5rem; }
  .num { color: var(--accent); }
  .sep { color: var(--text-faint); }
  .back { color: var(--text-secondary); }
  .back:hover { color: var(--accent); }

  .posts { list-style: none; margin: 0; padding: 0; }
  .post + .post .row { border-top: 1px dashed var(--border-subtle); }

  .row {
    display: grid;
    grid-template-columns: 110px 1fr;
    grid-template-areas: "date title" ". desc" ". tags";
    column-gap: 1.25rem;
    padding: 1.25rem 0.5rem;
    color: inherit;
    border-left: 2px solid transparent;
    transition: background 150ms ease, border-color 150ms ease;
  }
  .row:hover { background: var(--surface); border-left-color: var(--accent); }

  .date { grid-area: date; color: var(--text-muted); font-size: 0.875rem; padding-top: 0.125rem; }
  .title {
    grid-area: title;
    color: var(--text-primary);
    font-size: 1.1875rem;
    font-weight: 600;
    display: flex;
    align-items: baseline;
    gap: 0.375rem;
    transition: color 150ms ease;
  }
  .chev { color: var(--text-faint); transition: color 150ms ease, transform 150ms ease; }
  .row:hover .title { color: var(--accent); }
  .row:hover .chev { color: var(--accent); transform: translateX(2px); }

  .desc {
    grid-area: desc;
    color: var(--text-muted);
    font-size: 0.9375rem;
    line-height: 1.65;
    margin: 0.375rem 0 0;
    text-wrap: pretty;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .tags { grid-area: tags; margin-top: 0.5rem; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .tag { font-size: 0.8125rem; color: var(--text-muted); transition: color 150ms ease; }
  .tag.current { color: var(--accent); }
  .row:hover .tag { color: var(--accent-dim); }
  .row:hover .tag.current { color: var(--accent); }

  @media (max-width: 640px) {
    .row {
      grid-template-columns: 1fr;
      grid-template-areas: "date" "title" "desc" "tags";
      gap: 0.25rem;
    }
  }
</style>
