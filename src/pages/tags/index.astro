---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("posts");
const tagCounts = allPosts.reduce<Record<string, number>>((acc, p) => {
  for (const t of p.data.tags) acc[t] = (acc[t] ?? 0) + 1;
  return acc;
}, {});
const tags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);
---

<Layout title="">
  <section class="tags-page">
    <header class="head">
      <div class="cmd">
        <span class="prompt">$</span> ls tags/
        <span class="pipe">|</span> sort
      </div>
      <div class="meta">
        <span>total <span class="num">{tags.length}</span></span>
        <span class="sep">·</span>
        <span>{allPosts.length} posts</span>
      </div>
    </header>

    <ul class="grid">
      {tags.map(([t, count]) => (
        <li>
          <a href={`/tags/${t}`} class="tag" data-astro-prefetch>
            <span class="hash">#</span>
            <span class="name">{t}</span>
            <span class="count">×{count}</span>
          </a>
        </li>
      ))}
    </ul>

    {tags.length === 0 && (
      <div class="empty">总 0 · 还没有标签。</div>
    )}
  </section>
</Layout>

<style>
  .tags-page {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding: 1rem 0;
  }
  .head {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding-bottom: 1rem;
    border-bottom: 1px dashed var(--border-default);
  }
  .cmd { font-size: 1.0625rem; color: var(--text-primary); }
  .prompt { color: var(--accent); margin-right: 0.5rem; }
  .pipe { color: var(--text-faint); margin: 0 0.25rem; }
  .meta {
    padding-left: 1.25rem;
    font-size: 0.875rem;
    color: var(--text-muted);
    display: flex;
    gap: 0.5rem;
  }
  .num { color: var(--accent); }
  .sep { color: var(--text-faint); }

  .grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    display: inline-flex;
    align-items: baseline;
    gap: 0.5rem;
    padding: 0.5rem 0.875rem;
    color: var(--text-secondary);
    background: var(--surface);
    border: 1px solid var(--border-default);
    border-radius: 4px;
    font-size: 0.9375rem;
    white-space: nowrap;
    transition: border-color 150ms ease, background 150ms ease, color 150ms ease;
  }
  .hash { color: var(--text-faint); }
  .name { /* let content size naturally */ }
  .count { color: var(--text-muted); font-size: 0.8125rem; }
  .tag:hover {
    color: var(--accent);
    background: var(--elevated);
    border-color: var(--accent-dim);
  }
  .tag:hover .hash { color: var(--accent-dim); }
  .tag:hover .count { color: var(--text-secondary); }

  .empty { color: var(--text-muted); padding: 2rem 0; }
</style>
