---
import Layout from "../layouts/Layout.astro";
import { getCollection } from "astro:content";

const allPosts = (await getCollection("posts")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

function pad(n: number, w = 2) {
  return n.toString().padStart(w, "0");
}
function fmtDate(d: Date) {
  return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}`;
}

const groups = allPosts.reduce<Record<string, typeof allPosts>>((acc, p) => {
  const y = p.data.pubDate.getFullYear().toString();
  (acc[y] ??= []).push(p);
  return acc;
}, {});
const years = Object.keys(groups).sort((a, b) => Number(b) - Number(a));
const total = allPosts.length;
---

<Layout title="">
  <section class="list">
    <header class="list-head">
      <div class="cmd">
        <span class="prompt">$</span> find . -name "*.md" -type f
        <span class="pipe">|</span> sort -r
      </div>
      <div class="meta">
        <span>total <span class="num">{total}</span></span>
        <span class="sep">·</span>
        <span>{years.length} year{years.length > 1 ? "s" : ""}</span>
      </div>
    </header>

    {years.map((year) => (
      <section class="year">
        <div class="year-bar">
          <span class="year-num">── {year} </span>
          <span class="year-fill"></span>
          <span class="year-count">{groups[year].length} posts</span>
        </div>

        <ul class="posts">
          {groups[year].map((p) => (
            <li class="post">
              <a href={`/posts/${p.slug}`} class="row" data-astro-prefetch>
                <span class="date">{fmtDate(p.data.pubDate)}</span>
                <span class="title">
                  <span class="chev">›</span>
                  {p.data.title}
                </span>
                <p class="desc">{p.data.description}</p>
                {p.data.tags?.length > 0 && (
                  <div class="tags">
                    {p.data.tags.map((t) => (
                      <span class="tag">#{t}</span>
                    ))}
                  </div>
                )}
              </a>
            </li>
          ))}
        </ul>
      </section>
    ))}

    {total === 0 && (
      <div class="empty">
        <pre>total 0 · 还没有文章。</pre>
      </div>
    )}
  </section>
</Layout>

<style>
  .list {
    display: flex;
    flex-direction: column;
    gap: 2.5rem;
    padding: 1rem 0;
  }

  .list-head {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
    padding-bottom: 1rem;
    border-bottom: 1px dashed var(--border-default);
  }
  .cmd {
    font-size: 1.0625rem;
    color: var(--text-primary);
  }
  .prompt { color: var(--accent); margin-right: 0.5rem; }
  .pipe { color: var(--text-faint); margin: 0 0.25rem; }

  .meta {
    padding-left: 1.25rem;
    font-size: 0.875rem;
    color: var(--text-muted);
    display: flex;
    gap: 0.5rem;
  }
  .num { color: var(--accent); }
  .sep { color: var(--text-faint); }

  .year {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .year-bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--text-muted);
    font-size: 0.875rem;
  }
  .year-num { color: var(--accent); font-weight: 500; }
  .year-fill {
    flex: 1;
    height: 1px;
    border-top: 1px dashed var(--border-default);
  }

  .posts {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
  }

  .post + .post .row {
    border-top: 1px dashed var(--border-subtle);
  }

  .row {
    display: grid;
    grid-template-columns: 110px 1fr;
    grid-template-areas:
      "date  title"
      ".     desc"
      ".     tags";
    column-gap: 1.25rem;
    padding: 1.25rem 0.75rem 1.25rem 0.5rem;
    color: inherit;
    border-left: 2px solid transparent;
    transition: background 150ms ease, border-color 150ms ease;
  }
  .row:hover {
    background: var(--surface);
    border-left-color: var(--accent);
  }

  .date {
    grid-area: date;
    color: var(--text-muted);
    font-size: 0.875rem;
    padding-top: 0.125rem;
  }

  .title {
    grid-area: title;
    color: var(--text-primary);
    font-size: 1.1875rem;
    font-weight: 600;
    display: flex;
    align-items: baseline;
    gap: 0.375rem;
    transition: color 150ms ease;
  }
  .chev {
    color: var(--text-faint);
    transition: color 150ms ease, transform 150ms ease;
  }
  .row:hover .title { color: var(--accent); }
  .row:hover .chev {
    color: var(--accent);
    transform: translateX(2px);
  }

  .desc {
    grid-area: desc;
    color: var(--text-muted);
    font-size: 0.9375rem;
    line-height: 1.65;
    margin: 0.375rem 0 0;
    text-wrap: pretty;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .tags {
    grid-area: tags;
    margin-top: 0.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .tag {
    font-size: 0.8125rem;
    color: var(--text-muted);
    transition: color 150ms ease;
  }
  .row:hover .tag { color: var(--accent-dim); }

  @media (max-width: 640px) {
    .row {
      grid-template-columns: 1fr;
      grid-template-areas:
        "date"
        "title"
        "desc"
        "tags";
      gap: 0.25rem;
    }
  }

  .empty {
    color: var(--text-muted);
    padding: 2rem 0;
  }
  .empty pre {
    background: transparent;
    border: 0;
    padding: 0;
    color: inherit;
  }
</style>
