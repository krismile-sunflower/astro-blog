---
import Layout from "./Layout.astro";
const { frontmatter, data } = Astro.props;

const headings: { level: number; text: string; id: string }[] = [];

data.split("\n").forEach((line: string) => {
  const match = line.trim().match(/^(#{1,6})\s+(.*)/);
  if (match) {
    const level = match[1].length;
    const text = match[2];
    const id = text.toLowerCase().replace(/\s+/g, "-");
    headings.push({ level, text, id });
  }
});
---

<Layout title={frontmatter.title}>
  <article
    class="post"
    data-pagefind-body
    data-pagefind-meta={`title:${frontmatter.title}`}
  >
    <div data-pagefind-meta={`date:${frontmatter.pubDate.toString().slice(0, 10)}`} hidden></div>
    {frontmatter.tags?.map((t: string) => (
      <span data-pagefind-filter={`tag:${t}`} hidden></span>
    ))}

    <div class="metadata" data-pagefind-ignore>
      <div class="meta-row">
        <span class="key">date</span>
        <span class="val">{frontmatter.pubDate.toString().slice(0, 10)}</span>
      </div>
      <div class="meta-row">
        <span class="key">author</span>
        <span class="val">{frontmatter.author}</span>
      </div>
      <div class="meta-row">
        <span class="key">read</span>
        <span class="val">{frontmatter.minutesRead}</span>
      </div>
      {frontmatter.tags?.length > 0 && (
        <div class="meta-row">
          <span class="key">tags</span>
          <span class="val tags">
            {frontmatter.tags.map((tag: string) => (
              <a href={`/tags/${tag}`} class="tag">#{tag}</a>
            ))}
          </span>
        </div>
      )}
    </div>

    {frontmatter.description && (
      <blockquote class="abstract">
        <span class="abstract-mark">/* </span>
        {frontmatter.description}
        <span class="abstract-mark"> */</span>
      </blockquote>
    )}

    <div class="prose post-body">
      <slot />
    </div>
  </article>

  {headings.length > 0 && (
    <aside class="toc" aria-label="table of contents">
      <div class="toc-head">
        <span class="prompt">$</span> grep '^#' {(frontmatter.title || "post")}.md
      </div>
      <ul id="nav" class="toc-list">
        {headings.map((heading) => (
          <li
            class={`toc-item lvl-${heading.level}`}
            style={{ paddingLeft: `${(heading.level - 1) * 12}px` }}
          >
            <a href={`#${heading.id}`} class="toc-link">
              <span class="bullet">›</span>
              {heading.text}
            </a>
          </li>
        ))}
      </ul>
    </aside>
  )}
</Layout>

<style>
  .post {
    padding: 0.5rem 0 2rem;
  }

  .metadata {
    display: grid;
    grid-template-columns: 76px 1fr;
    gap: 0.375rem 1rem;
    padding: 1rem 1.25rem;
    background: var(--surface);
    border: 1px solid var(--border-default);
    border-radius: 4px;
    margin-bottom: 1.5rem;
    font-size: 0.875rem;
  }
  .meta-row {
    display: contents;
  }
  .key { color: var(--text-muted); }
  .key::before { content: "--"; color: var(--text-faint); margin-right: 0.375rem; }
  .val { color: var(--text-secondary); }
  .val.tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .tag {
    color: var(--accent);
    transition: opacity 150ms ease;
  }
  .tag:hover { opacity: 0.7; }

  .abstract {
    border-left: 2px solid var(--accent-dim);
    padding: 0.875rem 1.125rem;
    margin: 0 0 2rem;
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.7;
    background: transparent;
  }
  .abstract-mark { color: var(--accent-dim); }

  .post-body {
    max-width: none;
  }

  .toc {
    display: none;
  }

  @media (min-width: 1280px) {
    .toc {
      display: block;
      position: fixed;
      top: 6rem;
      right: max(1rem, calc((100vw - 64rem) / 2 - 16rem));
      width: 14rem;
      max-height: calc(100vh - 8rem);
      overflow-y: auto;
      padding: 1rem;
      background: var(--surface);
      border: 1px solid var(--border-default);
      border-radius: 4px;
      font-size: 0.875rem;
    }
  }

  .toc-head {
    font-size: 0.8125rem;
    color: var(--text-muted);
    padding-bottom: 0.5rem;
    border-bottom: 1px dashed var(--border-subtle);
    margin-bottom: 0.5rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .prompt { color: var(--accent); margin-right: 0.25rem; }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .toc-item { margin: 0; }
  .toc-link {
    display: flex;
    gap: 0.375rem;
    padding: 0.25rem 0;
    color: var(--text-muted);
    transition: color 150ms ease;
    text-wrap: pretty;
  }
  .toc-link .bullet { color: var(--text-faint); }
  .toc-link:hover { color: var(--text-primary); }
  .toc-link:hover .bullet { color: var(--accent); }
  .toc-link.active {
    color: var(--accent);
  }
  .toc-link.active .bullet { color: var(--accent); }
</style>

<script>
  document.querySelectorAll("#nav .toc-link").forEach((anchor) => {
    anchor.classList.remove("active");
    anchor.addEventListener("click", function (e) {
      document
        .querySelectorAll("#nav .toc-link")
        .forEach((a) => a.classList.remove("active"));
      if (e.target) (e.currentTarget as Element).classList.add("active");
    });
  });

  const handleIntersection: IntersectionObserverCallback = (entries) => {
    const visible: IntersectionObserverEntry[] = [];
    entries.forEach((entry) => entry.isIntersecting && visible.push(entry));
    if (visible.length) {
      const id = visible[0].target.getAttribute("id");
      const navLink = document.querySelector(`#nav .toc-link[href="#${id}"]`);
      document
        .querySelectorAll("#nav .toc-link")
        .forEach((a) => a.classList.remove("active"));
      if (navLink) navLink.classList.add("active");
    }
  };

  const observer = new IntersectionObserver(handleIntersection, {
    root: null,
    rootMargin: "0px 0px -50% 0px",
    threshold: 0.0,
  });
  document
    .querySelectorAll("h1[id], h2[id], h3[id], h4[id], h5[id], h6[id]")
    .forEach((heading) => observer.observe(heading));
</script>
