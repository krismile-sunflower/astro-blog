---
import "@fontsource/kalam";
import Header from "./Header.astro";
import Footer from "./Footer.astro";
import "../styles/global.css";
import { ViewTransitions } from "astro:transitions";
import LevitationMenu from "@components/LevitationMenu";
const { title } = Astro.props;
---

<html lang="zh-cn">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="RSS"
      href="/rss.xml"
    />
    <link rel="manifest" href="/mainfest.json" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="你的网站标题"
      href={new URL("rss.xml", Astro.site)}
    />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ViewTransitions />
  </head>
  <body>
    <div class="flex flex-col min-h-screen">
      <Header />
      <div class="flex-grow">
        <div class="glass cyber-border rounded-2xl mx-4 sm:mx-8 md:mx-16 lg:mx-32 xl:mx-48 mt-24 mb-8 p-8 relative overflow-hidden">
          <!-- 背景网格装饰 -->
          <div class="absolute inset-0 grid-bg opacity-20 pointer-events-none"></div>

          <!-- 标题区域 -->
          <div class="relative z-10">
            <h1 class="font-heading text-4xl md:text-5xl font-bold mb-6 gradient-text neon-text">{title}</h1>
            <div class="prose prose-lg dark:prose-invert max-w-none font-body">
              <slot />
            </div>
          </div>
        </div>
      </div>
      <div class="fixed bottom-10 right-0 z-50">
        <LevitationMenu client:load />
      </div>
      <Footer />
    </div>
    <script>
      import "../scripts/click-effect.js"
      if ("serviceWorker" in navigator) {
        navigator.serviceWorker.register("/sw.js");
      }
    </script>
  </body>
</html>
